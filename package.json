{
  "name": "pulse",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "dev:api": "npm run start:dev -w apps/api",
    "dev:all": "npm run dev -w apps/web & npm run start:dev -w apps/api",
    "build": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "lint": "npm run lint -w apps/web",
    "typecheck": "npm run typecheck -w apps/web && npm run typecheck -w apps/api",
    "test": "npm run test:run -w apps/web",
    "test:api": "npm run test:e2e -w apps/api",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/api/**/*.ts": [
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "prisma@6.19.3": true,
    "unrs-resolver@1.12.2": true
  }
}
