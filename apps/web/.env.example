# Base URL of the Pulse backend API (NestJS, apps/api).
# Local dev: matches apps/api/.env PORT=3000 + global prefix "api".
# Production: replace with the deployed backend URL (Railway — not deployed yet, see ROADMAP.md Фаза 1.6/3.2).
VITE_API_URL=http://localhost:3000/api

# Optional client log level for shared/lib/logger.ts.
# One of: debug | info | warn | error | silent.
# Defaults to `debug` in dev and `warn` in production builds when unset.
# VITE_LOG_LEVEL=debug
