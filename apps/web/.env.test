# Loaded by Vitest (Vite mode = "test"). Committed on purpose so CI sees it too.
# Unit tests mock `fetch`, so the value is never actually requested — defining it
# just keeps httpClient logs readable (avoids "GET undefined/metrics...").
VITE_API_URL=http://localhost:3000/api

# Quiet the noisy debug/info traces (e.g. "[httpClient] → GET ...") during unit
# tests, while keeping warn/error so tests that assert on warnings still pass.
# Set to `debug` locally if you want the verbose httpClient traces back.
VITE_LOG_LEVEL=warn
